<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista lista de categorías -->
    <record id="vista_categorias_lista" model="ir.ui.view">
        <field name="name">Categorías - Vista Lista</field>
        <field name="model">product.category</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Lista de Categorías" editable="bottom" create="true">
                <field name="name" string="Nombre Categoría" />
                <field name="parent_id" string="Categoría Padre" optional="show" />
            </list>
        </field>
    </record>

    <!-- Formulario de categorías -->
    <record id="vista_categorias_formulario" model="ir.ui.view">
        <field name="name">Categorías - Vista Formulario</field>
        <field name="model">product.category</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Categoría">
                <sheet>
                    <notebook>
                        <!-- Pestaña 1: Información de la categoría -->
                        <page string="Información General">
                            <group>
                                <group>
                                    <field name="name" string="Nombre Categoría" required="1" placeholder="Ej: Bebidas" />
                                </group>
                                <group>
                                    <field name="parent_id" string="Categoría Padre" />
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña 2: Auditoría -->
                        <page string="Información Adicional" groups="base.group_no_one">
                            <group string="Auditoría">
                                <group>
                                    <field name="create_uid" string="Creado por" readonly="1" />
                                </group>
                                <group>
                                    <field name="create_date" string="Fecha de Creación" readonly="1" />
                                </group>
                            </group>

                            <group string="Última Modificación">
                                <group>
                                    <field name="write_uid" string="Modificado por" readonly="1" />
                                </group>
                                <group>
                                    <field name="write_date" string="Fecha de Modificación" readonly="1" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter"></div>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda -->
    <record id="vista_categorias_busqueda" model="ir.ui.view">
        <field name="name">Categorías - Vista de Búsqueda</field>
        <field name="model">product.category</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Buscar Categorías">
                <field name="name" string="Nombre Categoría" />

                <separator />

                <group expand="0" string="Agrupar por...">
                    <filter name="agrupar_nombre" string="Nombre" context="{'group_by': 'name'}" />
                    <filter name="agrupar_padre" string="Categoría Padre" context="{'group_by': 'parent_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de ventana para abrir categorías -->
    <record id="accion_categorias" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">product.category</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="vista_categorias_lista" />
        <field name="domain" eval="[('id', 'child_of', ref('category_alimentos'))]" />
        <field name="help">Catálogo de categorías de productos Nestlé.</field>
    </record>

</odoo>