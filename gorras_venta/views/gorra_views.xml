<odoo>
    <!--REGISTRO DE GORRA -->
    <record id="view_gorra_form" model="ir.ui.view">
        <field name="name">gorras.gorra.form</field>
        <field name="model">gorras.gorra</field>
        <field name="arch" type="xml">
            <form string="Venta de Gorras">
                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="color"/>
                        <field name="precio"/>
                        <field name="zapato_recomendado_id"/>
                    </group>  
                </sheet>      
            </form>    
        </field>    
    </record>

    <!--LISTADO DE GORRAS que se van ingresando  - MOSTRAR-->
    <record id="view_gorra_list" model="ir.ui.view">
        <field name="name">gorras.gorra.list</field>
        <field name="model">gorras.gorra</field>
        <field name="arch" type="xml">
            <list string="Gorreria">
                <field name="nombre"/>
                <field name="color"/>
                <field name="precio"/>
                <field name="zapato_recomendado_id"/>
            </list>        
        </field>    
    </record>

    <!-- Mostrar todas las gorras que ya se guardaron - REGISTRO TOTAL -->
    <record id='action_gorras' model="ir.actions.act_window">
        <field name="name">GORRERIA</field>
        <field name="res_model">gorras.gorra</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU PRINCIPAL-->
    <menuitem id="menu_gorras_root" name="Gorreria" sequence="20"/>

    <!-- Submenu-->
    <menuitem id="menu_gorras"
              name="Gorras"
              parent="menu_gorras_root"
              action="action_gorras"
              sequence="1"/>

</odoo>